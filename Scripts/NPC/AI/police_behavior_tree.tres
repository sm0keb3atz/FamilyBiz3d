[gd_resource type="BehaviorTree" load_steps=10 format=3]

[ext_resource type="Script" path="res://Scripts/NPC/AI/police_wanted_condition.gd" id="1_condition"]
[ext_resource type="Script" path="res://Scripts/NPC/AI/police_mode_action.gd" id="2_action"]

[sub_resource type="BTCondition" id="BTCondition_combat"]
script = ExtResource("1_condition")
minimum_level = 2
maximum_level = 3

[sub_resource type="BTAction" id="BTAction_combat"]
script = ExtResource("2_action")
mode = 2

[sub_resource type="BTSequence" id="BTSequence_combat"]
custom_name = "Lethal combat"
children = [SubResource("BTCondition_combat"), SubResource("BTAction_combat")]

[sub_resource type="BTCondition" id="BTCondition_arrest"]
script = ExtResource("1_condition")
minimum_level = 1
maximum_level = 1

[sub_resource type="BTAction" id="BTAction_arrest"]
script = ExtResource("2_action")
mode = 1

[sub_resource type="BTSequence" id="BTSequence_arrest"]
custom_name = "Arrest pursuit"
children = [SubResource("BTCondition_arrest"), SubResource("BTAction_arrest")]

[sub_resource type="BTAction" id="BTAction_patrol"]
script = ExtResource("2_action")
mode = 0

[sub_resource type="BTSelector" id="BTSelector_root"]
custom_name = "Police priority"
children = [SubResource("BTSequence_combat"), SubResource("BTSequence_arrest"), SubResource("BTAction_patrol")]

[resource]
description = "Police priority: lethal combat, arrest pursuit, then pedestrian patrol."
root_task = SubResource("BTSelector_root")
